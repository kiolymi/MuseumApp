<Window x:Class="MuseumApp.Windows.Inventories.EditInventoryWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Title="Изменить остаток" Height="200" Width="460" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
<Grid Margin="16"><Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
<Label Content="Магазин:"/><ComboBox x:Name="cmbShop" Grid.Row="1" IsEnabled="False" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="0,0,0,8"/>
<Label Grid.Row="2" Content="Товар:"/><ComboBox x:Name="cmbProduct" Grid.Row="2" IsEnabled="False" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="0,0,0,8"/>
<Label Grid.Row="3" Content="Количество:"/><TextBox x:Name="txtQty" Grid.Row="3" Margin="0,0,0,8"/>
<Button Grid.Row="4" Content="Сохранить" Height="32" Click="btnSave_Click"/></Grid></Window>
