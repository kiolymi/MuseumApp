<Window x:Class="MuseumApp.Windows.Inventories.AddInventoryWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Title="Добавить остаток" Height="200" Width="460" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Style="{StaticResource DialogWindow}">
<Grid Margin="16"><Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
<Label Content="Магазин:"/><ComboBox x:Name="cmbShop" Grid.Row="1" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="0,0,0,8"/>
<Label Grid.Row="2" Content="Товар:"/><ComboBox x:Name="cmbProduct" Grid.Row="2" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="0,0,0,8"/>
<Label Grid.Row="3" Content="Количество:"/><TextBox x:Name="txtQty" Grid.Row="3" Margin="0,0,0,8"/>
<Button Grid.Row="4" Content="Добавить" Height="32" Click="btnAdd_Click"/></Grid></Window>
