<Window x:Class="MuseumApp.Windows.ExhibitMovements.AddExhibitMovementWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Title="Добавить перемещение" Height="340" Width="480" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Style="{StaticResource DialogWindow}">
<Grid Margin="16"><Grid.RowDefinitions>
<RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
<Label Content="Экспонат:"/><ComboBox x:Name="cmbExhibit" Grid.Row="1" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="0,0,0,8"/>
<Label Grid.Row="2" Content="Ответственный:"/><ComboBox x:Name="cmbResponsible" Grid.Row="2" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="0,0,0,8"/>
<Label Grid.Row="3" Content="Из хранилища:"/><ComboBox x:Name="cmbFrom" Grid.Row="3" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="0,0,0,8"/>
<Label Grid.Row="4" Content="В хранилище:"/><ComboBox x:Name="cmbTo" Grid.Row="4" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="0,0,0,8"/>
<Label Grid.Row="5" Content="Дата:"/><DatePicker x:Name="dpDate" Grid.Row="5" Margin="0,0,0,8"/>
<Label Grid.Row="6" Content="Причина:"/><ComboBox x:Name="cmbReason" Grid.Row="6" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="0,0,0,8"/>
<Button Grid.Row="7" Content="Добавить" Height="32" Click="btnAdd_Click"/></Grid></Window>
