<Window x:Class="MuseumApp.Windows.Products.AddProductWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Title="Добавить товар" Height="260" Width="460" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Style="{StaticResource DialogWindow}">
<Grid Margin="16"><Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
<Label Content="Название:"/><TextBox x:Name="txtName" Grid.Row="1" Margin="0,0,0,8"/>
<Label Grid.Row="2" Content="Описание:"/><TextBox x:Name="txtDesc" Grid.Row="2" Margin="0,0,0,8"/>
<Label Grid.Row="3" Content="Цена:"/><TextBox x:Name="txtPrice" Grid.Row="3" Margin="0,0,0,8"/>
<Label Grid.Row="4" Content="Поставщик:"/><ComboBox x:Name="cmbCompany" Grid.Row="4" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="0,0,0,8"/>
<Button Grid.Row="5" Content="Добавить" Height="32" Click="btnAdd_Click"/></Grid></Window>
