<Window x:Class="MuseumApp.Windows.Branches.EditBranchWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Title="Изменить филиал" Height="300" Width="460" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#F2F6FA" FontFamily="Segoe UI" FontSize="14" Foreground="#1E2D3D">
<Grid Margin="16"><Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
<Label FontWeight="SemiBold" Foreground="#1E2D3D" VerticalAlignment="Center"  Content="Музей:"/><ComboBox Height="36" Padding="8,4" Background="#FFFFFF" BorderBrush="#C8D8E8" BorderThickness="1" Foreground="#1E2D3D"  x:Name="cmbMuseum" Grid.Row="1" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="0,0,0,8"/>
<Label FontWeight="SemiBold" Foreground="#1E2D3D" VerticalAlignment="Center"  Grid.Row="2" Content="Название:"/><TextBox Height="34" Padding="10,6" Background="#FFFFFF" BorderBrush="#C8D8E8" BorderThickness="1" Foreground="#1E2D3D"  x:Name="txtName" Grid.Row="2" Margin="0,0,0,8"/>
<Label FontWeight="SemiBold" Foreground="#1E2D3D" VerticalAlignment="Center"  Grid.Row="3" Content="Адрес:"/><ComboBox Height="36" Padding="8,4" Background="#FFFFFF" BorderBrush="#C8D8E8" BorderThickness="1" Foreground="#1E2D3D"  x:Name="cmbAddress" Grid.Row="3" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="0,0,0,8"/>
<Label FontWeight="SemiBold" Foreground="#1E2D3D" VerticalAlignment="Center"  Grid.Row="4" Content="Телефон:"/><TextBox Height="34" Padding="10,6" Background="#FFFFFF" BorderBrush="#C8D8E8" BorderThickness="1" Foreground="#1E2D3D"  x:Name="txtPhone" Grid.Row="4" Margin="0,0,0,8"/>
<Label FontWeight="SemiBold" Foreground="#1E2D3D" VerticalAlignment="Center"  Grid.Row="5" Content="Ответственный:"/><ComboBox Height="36" Padding="8,4" Background="#FFFFFF" BorderBrush="#C8D8E8" BorderThickness="1" Foreground="#1E2D3D"  x:Name="cmbResponsible" Grid.Row="5" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="0,0,0,8"/>
<Button Grid.Row="6" Content="Сохранить" Height="36" MinWidth="100" Padding="18,0" Background="#1A3D5C" Foreground="White" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand" Click="btnSave_Click"/></Grid></Window>
