<Window x:Class="MuseumApp.Windows.Branches.EditBranchWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Title="Изменить филиал" Height="300" Width="460" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Style="{StaticResource DialogWindow}">
<Grid Margin="16"><Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
<Label Content="Музей:"/><ComboBox x:Name="cmbMuseum" Grid.Row="1" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="0,0,0,8"/>
<Label Grid.Row="2" Content="Название:"/><TextBox x:Name="txtName" Grid.Row="2" Margin="0,0,0,8"/>
<Label Grid.Row="3" Content="Адрес:"/><ComboBox x:Name="cmbAddress" Grid.Row="3" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="0,0,0,8"/>
<Label Grid.Row="4" Content="Телефон:"/><TextBox x:Name="txtPhone" Grid.Row="4" Margin="0,0,0,8"/>
<Label Grid.Row="5" Content="Ответственный:"/><ComboBox x:Name="cmbResponsible" Grid.Row="5" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="0,0,0,8"/>
<Button Grid.Row="6" Content="Сохранить" Height="32" Click="btnSave_Click"/></Grid></Window>
