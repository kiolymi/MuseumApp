<Window x:Class="MuseumApp.Windows.Events.EditEventWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Изменить мероприятие" Height="420" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Style="{StaticResource DialogWindow}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="140"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Label Grid.Row="0" Grid.Column="0" Content="Название:"/>
        <TextBox x:Name="txtName" Grid.Row="0" Grid.Column="1" Margin="0,0,0,8"/>

        <Label Grid.Row="1" Grid.Column="0" Content="Филиал:"/>
        <ComboBox x:Name="cmbBranch" Grid.Row="1" Grid.Column="1" Margin="0,0,0,8"
                  DisplayMemberPath="Name" SelectedValuePath="Id"/>

        <Label Grid.Row="2" Grid.Column="0" Content="Сотрудник:"/>
        <ComboBox x:Name="cmbEmployee" Grid.Row="2" Grid.Column="1" Margin="0,0,0,8"
                  DisplayMemberPath="Name" SelectedValuePath="Id"/>

        <Label Grid.Row="3" Grid.Column="0" Content="Дата:"/>
        <DatePicker x:Name="dpEventDate" Grid.Row="3" Grid.Column="1" Margin="0,0,0,8"/>

        <Label Grid.Row="4" Grid.Column="0" Content="Время начала:"/>
        <TextBox x:Name="txtStartTime" Grid.Row="4" Grid.Column="1" Margin="0,0,0,8"/>

        <Label Grid.Row="5" Grid.Column="0" Content="Длительность (мин):"/>
        <TextBox x:Name="txtDuration" Grid.Row="5" Grid.Column="1" Margin="0,0,0,8"/>

        <Label Grid.Row="6" Grid.Column="0" Content="Цена:"/>
        <TextBox x:Name="txtPrice" Grid.Row="6" Grid.Column="1" Margin="0,0,0,8"/>

        <Button Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2" Content="Сохранить"
                Height="32" Click="btnSave_Click"/>
    </Grid>
</Window>
