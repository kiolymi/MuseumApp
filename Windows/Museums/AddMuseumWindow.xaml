<Window x:Class="MuseumApp.Windows.Museums.AddMuseumWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Title="Добавить музей" Height="220" Width="460" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
<Grid Margin="16"><Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
<Label Content="Название:"/><TextBox x:Name="txtName" Grid.Row="1" Margin="0,0,0,8"/>
<Label Grid.Row="2" Content="Директор:"/><ComboBox x:Name="cmbDirector" Grid.Row="2" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="0,0,0,8"/>
<Label Grid.Row="3" Content="Адрес:"/><ComboBox x:Name="cmbAddress" Grid.Row="3" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="0,0,0,8"/>
<Button Grid.Row="4" Content="Добавить" Height="32" Click="btnAdd_Click"/></Grid></Window>
