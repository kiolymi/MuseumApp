<Window x:Class="MuseumApp.Windows.Links.AddExhibitionHallLinkWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавить связь выставка-зал" Height="220" Width="460" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#F2F6FA" FontFamily="Segoe UI" FontSize="14" Foreground="#1E2D3D">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Label FontWeight="SemiBold" Foreground="#1E2D3D" VerticalAlignment="Center"  Content="Выставка:"/>
        <ComboBox Height="36" Padding="8,4" Background="#FFFFFF" BorderBrush="#C8D8E8" BorderThickness="1" Foreground="#1E2D3D"  x:Name="cmb1" Grid.Row="1" Margin="0,0,0,12" DisplayMemberPath="Name" SelectedValuePath="Id"/>
        <Label FontWeight="SemiBold" Foreground="#1E2D3D" VerticalAlignment="Center"  Grid.Row="2" Content="Зал:"/>
        <ComboBox Height="36" Padding="8,4" Background="#FFFFFF" BorderBrush="#C8D8E8" BorderThickness="1" Foreground="#1E2D3D"  x:Name="cmb2" Grid.Row="3" Margin="0,0,0,12" DisplayMemberPath="Name" SelectedValuePath="Id"/>
        <Button Grid.Row="5" Content="Добавить" Height="36" MinWidth="100" Padding="18,0" Background="#1A3D5C" Foreground="White" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand" Click="btnAdd_Click"/>
    </Grid>
</Window>
