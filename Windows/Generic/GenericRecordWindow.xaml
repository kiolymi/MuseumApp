<Window x:Class="MuseumApp.Windows.Generic.GenericRecordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Запись"
        Background="#F2F6FA"
        FontFamily="Segoe UI"
        FontSize="14"
        Foreground="#1E2D3D"
        SizeToContent="WidthAndHeight"
        MinWidth="440"
        MaxWidth="560">
    <Border Background="#FFFFFF"
            BorderBrush="#C8D8E8"
            BorderThickness="1"
            CornerRadius="12"
            Margin="16"
            Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <ScrollViewer Grid.Row="0" MaxHeight="480" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="fieldsPanel"/>
            </ScrollViewer>
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="Сохранить"
                        MinWidth="110"
                        Margin="0,0,8,0"
                        Height="36"
                        Padding="18,0"
                        Background="#1A3D5C"
                        Foreground="White"
                        FontWeight="SemiBold"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="btnSave_Click"
                        IsDefault="True"/>
                <Button Content="Отмена"
                        MinWidth="100"
                        Height="36"
                        Padding="18,0"
                        Background="#FFFFFF"
                        Foreground="#1A3D5C"
                        BorderBrush="#C8D8E8"
                        BorderThickness="1"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        IsCancel="True"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
