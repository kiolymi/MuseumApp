<Window x:Class="MuseumApp.Windows.Generic.GenericRecordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Запись"
        Style="{StaticResource DialogWindow}"
        SizeToContent="WidthAndHeight"
        MinWidth="440"
        MaxWidth="560">
    <Border Style="{StaticResource CardBorder}" Margin="16" Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <ScrollViewer Grid.Row="0" MaxHeight="480" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="fieldsPanel"/>
            </ScrollViewer>
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="Сохранить" MinWidth="110" Margin="0,0,8,0"
                        Click="btnSave_Click" IsDefault="True"/>
                <Button Content="Отмена" MinWidth="100" Style="{StaticResource SecondaryButton}" IsCancel="True"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
