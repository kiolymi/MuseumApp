<Window x:Class="MuseumApp.Windows.Halls.AddHallWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавить зал" Height="340" Width="480"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Label Grid.Row="0" Grid.Column="0" Content="Название:"/>
        <TextBox x:Name="txtName" Grid.Row="0" Grid.Column="1" Margin="0,0,0,8"/>

        <Label Grid.Row="1" Grid.Column="0" Content="Филиал:"/>
        <ComboBox x:Name="cmbBranch" Grid.Row="1" Grid.Column="1" Margin="0,0,0,8"
                  DisplayMemberPath="Name" SelectedValuePath="Id"/>

        <Label Grid.Row="2" Grid.Column="0" Content="Площадь:"/>
        <TextBox x:Name="txtArea" Grid.Row="2" Grid.Column="1" Margin="0,0,0,8"/>

        <Label Grid.Row="3" Grid.Column="0" Content="Вместимость:"/>
        <TextBox x:Name="txtCapacity" Grid.Row="3" Grid.Column="1" Margin="0,0,0,8"/>

        <Button Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Content="Добавить"
                Height="32" Click="btnAdd_Click"/>
    </Grid>
</Window>
