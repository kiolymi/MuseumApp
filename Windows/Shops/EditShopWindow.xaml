<Window x:Class="MuseumApp.Windows.Shops.EditShopWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Title="Изменить магазин" Height="300" Width="460" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
<Grid Margin="16"><Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
<Label Content="Филиал:"/><ComboBox x:Name="cmbBranch" Grid.Row="1" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="0,0,0,8"/>
<Label Grid.Row="2" Content="Название:"/><TextBox x:Name="txtName" Grid.Row="2" Margin="0,0,0,8"/>
<Label Grid.Row="3" Content="Телефон:"/><TextBox x:Name="txtPhone" Grid.Row="3" Margin="0,0,0,8"/>
<Label Grid.Row="4" Content="E-mail:"/><TextBox x:Name="txtEmail" Grid.Row="4" Margin="0,0,0,8"/>
<Label Grid.Row="5" Content="Режим работы:"/><TextBox x:Name="txtHours" Grid.Row="5" Margin="0,0,0,8"/>
<Button Grid.Row="6" Content="Сохранить" Height="32" Click="btnSave_Click"/></Grid></Window>
