<Window x:Class="MuseumApp.Windows.Positions.EditPositionWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Title="Изменить должность" Height="260" Width="440" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Style="{StaticResource DialogWindow}">
<Grid Margin="16"><Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
<Label Content="Название:"/><TextBox x:Name="txtName" Grid.Row="1" Margin="0,0,0,8"/>
<Label Grid.Row="2" Content="Описание:"/><TextBox x:Name="txtDesc" Grid.Row="2" Margin="0,0,0,8"/>
<Label Grid.Row="3" Content="Оклад:"/><TextBox x:Name="txtSalary" Grid.Row="3" Margin="0,0,0,8"/>
<Button Grid.Row="4" Content="Сохранить" Height="32" Click="btnSave_Click"/></Grid></Window>
