<Window x:Class="MuseumApp.Windows.Exhibitions.AddExhibitionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавить выставку" Height="380" Width="480"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#F2F6FA" FontFamily="Segoe UI" FontSize="14" Foreground="#1E2D3D">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Label FontWeight="SemiBold" Foreground="#1E2D3D" VerticalAlignment="Center"  Grid.Row="0" Grid.Column="0" Content="Название:"/>
        <TextBox Height="34" Padding="10,6" Background="#FFFFFF" BorderBrush="#C8D8E8" BorderThickness="1" Foreground="#1E2D3D"  x:Name="txtName" Grid.Row="0" Grid.Column="1" Margin="0,0,0,8"/>

        <Label FontWeight="SemiBold" Foreground="#1E2D3D" VerticalAlignment="Center"  Grid.Row="1" Grid.Column="0" Content="Дата начала:"/>
        <DatePicker Height="36" Background="#FFFFFF" BorderBrush="#C8D8E8" BorderThickness="1" Foreground="#1E2D3D"  x:Name="dpStart" Grid.Row="1" Grid.Column="1" Margin="0,0,0,8"/>

        <Label FontWeight="SemiBold" Foreground="#1E2D3D" VerticalAlignment="Center"  Grid.Row="2" Grid.Column="0" Content="Дата окончания:"/>
        <DatePicker Height="36" Background="#FFFFFF" BorderBrush="#C8D8E8" BorderThickness="1" Foreground="#1E2D3D"  x:Name="dpEnd" Grid.Row="2" Grid.Column="1" Margin="0,0,0,8"/>

        <Label FontWeight="SemiBold" Foreground="#1E2D3D" VerticalAlignment="Center"  Grid.Row="3" Grid.Column="0" Content="Цена:"/>
        <TextBox Height="34" Padding="10,6" Background="#FFFFFF" BorderBrush="#C8D8E8" BorderThickness="1" Foreground="#1E2D3D"  x:Name="txtPrice" Grid.Row="3" Grid.Column="1" Margin="0,0,0,8"/>

        <Label FontWeight="SemiBold" Foreground="#1E2D3D" VerticalAlignment="Center"  Grid.Row="4" Grid.Column="0" Content="Тема:"/>
        <TextBox Height="34" Padding="10,6" Background="#FFFFFF" BorderBrush="#C8D8E8" BorderThickness="1" Foreground="#1E2D3D"  x:Name="txtTheme" Grid.Row="4" Grid.Column="1" Margin="0,0,0,8"/>

        <Label FontWeight="SemiBold" Foreground="#1E2D3D" VerticalAlignment="Center"  Grid.Row="5" Grid.Column="0" Content="Куратор:"/>
        <ComboBox Height="36" Padding="8,4" Background="#FFFFFF" BorderBrush="#C8D8E8" BorderThickness="1" Foreground="#1E2D3D"  x:Name="cmbCurator" Grid.Row="5" Grid.Column="1" Margin="0,0,0,8"
                  DisplayMemberPath="Name" SelectedValuePath="Id"/>

        <Button Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2" Content="Добавить" Height="36" MinWidth="100" Padding="18,0" Background="#1A3D5C" Foreground="White" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand" Click="btnAdd_Click"/>
    </Grid>
</Window>
