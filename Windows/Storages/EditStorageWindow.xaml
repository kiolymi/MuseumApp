<Window x:Class="MuseumApp.Windows.Storages.EditStorageWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Title="Изменить хранилище" Height="260" Width="460" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Style="{StaticResource DialogWindow}">
<Grid Margin="16"><Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
<Label Content="Название:"/><TextBox x:Name="txtName" Grid.Row="1" Margin="0,0,0,8"/>
<Label Grid.Row="2" Content="Филиал:"/><ComboBox x:Name="cmbBranch" Grid.Row="2" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="0,0,0,8"/>
<Label Grid.Row="3" Content="Температура:"/><TextBox x:Name="txtTemp" Grid.Row="3" Margin="0,0,0,8"/>
<Label Grid.Row="4" Content="Влажность:"/><TextBox x:Name="txtHumidity" Grid.Row="4" Margin="0,0,0,8"/>
<Button Grid.Row="5" Content="Сохранить" Height="32" Click="btnSave_Click"/></Grid></Window>
