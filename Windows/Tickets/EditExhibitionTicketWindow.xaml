<Window x:Class="MuseumApp.Windows.Tickets.EditExhibitionTicketWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Изменить билет на выставку" Height="320" Width="480"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#F2F6FA" FontFamily="Segoe UI" FontSize="14" Foreground="#1E2D3D">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Label FontWeight="SemiBold" Foreground="#1E2D3D" VerticalAlignment="Center"  Grid.Row="0" Grid.Column="0" Content="Посетитель ID:"/>
        <TextBlock x:Name="lblVisitor" Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" VerticalAlignment="Center"/>

        <Label FontWeight="SemiBold" Foreground="#1E2D3D" VerticalAlignment="Center"  Grid.Row="1" Grid.Column="0" Content="Выставка ID:"/>
        <TextBlock x:Name="lblExhibition" Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" VerticalAlignment="Center"/>

        <Label FontWeight="SemiBold" Foreground="#1E2D3D" VerticalAlignment="Center"  Grid.Row="2" Grid.Column="0" Content="Дата визита:"/>
        <DatePicker Height="36" Background="#FFFFFF" BorderBrush="#C8D8E8" BorderThickness="1" Foreground="#1E2D3D"  x:Name="dpVisitDate" Grid.Row="2" Grid.Column="1" Margin="0,0,0,8"/>

        <Label FontWeight="SemiBold" Foreground="#1E2D3D" VerticalAlignment="Center"  Grid.Row="3" Grid.Column="0" Content="Время (ЧЧ:ММ):"/>
        <TextBox Height="34" Padding="10,6" Background="#FFFFFF" BorderBrush="#C8D8E8" BorderThickness="1" Foreground="#1E2D3D"  x:Name="txtVisitTime" Grid.Row="3" Grid.Column="1" Margin="0,0,0,8"/>

        <Label FontWeight="SemiBold" Foreground="#1E2D3D" VerticalAlignment="Center"  Grid.Row="4" Grid.Column="0" Content="Стоимость:"/>
        <TextBox Height="34" Padding="10,6" Background="#FFFFFF" BorderBrush="#C8D8E8" BorderThickness="1" Foreground="#1E2D3D"  x:Name="txtActualCost" Grid.Row="4" Grid.Column="1" Margin="0,0,0,8"/>

        <Button Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Content="Сохранить" Height="36" MinWidth="100" Padding="18,0" Background="#1A3D5C" Foreground="White" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand" Click="btnSave_Click"/>
    </Grid>
</Window>
