<Window x:Class="MuseumApp.Windows.Restorations.AddRestorationWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Title="Добавить реставрацию" Height="320" Width="480" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Style="{StaticResource DialogWindow}">
<Grid Margin="16"><Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
<Label Content="Экспонат:"/><ComboBox x:Name="cmbExhibit" Grid.Row="1" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="0,0,0,8"/>
<Label Grid.Row="2" Content="Реставратор:"/><ComboBox x:Name="cmbRestorer" Grid.Row="2" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="0,0,0,8"/>
<Label Grid.Row="3" Content="Начало:"/><DatePicker x:Name="dpStart" Grid.Row="3" Margin="0,0,0,8"/>
<Label Grid.Row="4" Content="Окончание:"/><DatePicker x:Name="dpEnd" Grid.Row="4" Margin="0,0,0,8"/>
<Label Grid.Row="5" Content="Стоимость:"/><TextBox x:Name="txtCost" Grid.Row="5" Margin="0,0,0,8"/>
<Label Grid.Row="6" Content="Описание:"/><TextBox x:Name="txtDesc" Grid.Row="6" Margin="0,0,0,8"/>
<Button Grid.Row="7" Content="Добавить" Height="32" Click="btnAdd_Click"/></Grid></Window>
