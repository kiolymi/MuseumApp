<Window x:Class="MuseumApp.Windows.ExhibitConditions.AddExhibitConditionWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Title="Добавить состояние" Height="220" Width="440" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
<Grid Margin="16"><Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
<Label Content="Название:"/><TextBox x:Name="txtName" Grid.Row="1" Margin="0,0,0,8"/>
<Label Grid.Row="2" Content="Описание:"/><TextBox x:Name="txtDesc" Grid.Row="2" Margin="0,16,0,8"/>
<Button Grid.Row="3" Content="Добавить" Height="32" Click="btnAdd_Click"/></Grid></Window>
