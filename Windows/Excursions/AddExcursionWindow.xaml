<Window x:Class="MuseumApp.Windows.Excursions.AddExcursionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавить экскурсию" Height="400" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="140"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Label Grid.Row="0" Grid.Column="0" Content="Выставка:"/>
        <ComboBox x:Name="cmbExhibition" Grid.Row="0" Grid.Column="1" Margin="0,0,0,8"
                  DisplayMemberPath="Name" SelectedValuePath="Id"/>

        <Label Grid.Row="1" Grid.Column="0" Content="Гид:"/>
        <ComboBox x:Name="cmbGuide" Grid.Row="1" Grid.Column="1" Margin="0,0,0,8"
                  DisplayMemberPath="Name" SelectedValuePath="Id"/>

        <Label Grid.Row="2" Grid.Column="0" Content="Заказчик:"/>
        <ComboBox x:Name="cmbCustomer" Grid.Row="2" Grid.Column="1" Margin="0,0,0,8"
                  DisplayMemberPath="Name" SelectedValuePath="Id"/>

        <Label Grid.Row="3" Grid.Column="0" Content="Длительность (мин):"/>
        <TextBox x:Name="txtDuration" Grid.Row="3" Grid.Column="1" Margin="0,0,0,8" Text="90"/>

        <Label Grid.Row="4" Grid.Column="0" Content="Цена:"/>
        <TextBox x:Name="txtPrice" Grid.Row="4" Grid.Column="1" Margin="0,0,0,8"/>

        <Button Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2" Content="Добавить"
                Height="32" Click="btnAdd_Click"/>
    </Grid>
</Window>
