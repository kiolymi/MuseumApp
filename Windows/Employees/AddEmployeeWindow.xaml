<Window x:Class="MuseumApp.Windows.Employees.AddEmployeeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавить сотрудника" Height="420" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="130"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Label Grid.Row="0" Grid.Column="0" Content="Фамилия:"/>
        <TextBox x:Name="txtLastName" Grid.Row="0" Grid.Column="1" Margin="0,0,0,8"/>

        <Label Grid.Row="1" Grid.Column="0" Content="Имя:"/>
        <TextBox x:Name="txtFirstName" Grid.Row="1" Grid.Column="1" Margin="0,0,0,8"/>

        <Label Grid.Row="2" Grid.Column="0" Content="Отчество:"/>
        <TextBox x:Name="txtMiddleName" Grid.Row="2" Grid.Column="1" Margin="0,0,0,8"/>

        <Label Grid.Row="3" Grid.Column="0" Content="Должность:"/>
        <ComboBox x:Name="cmbPosition" Grid.Row="3" Grid.Column="1" Margin="0,0,0,8"
                  DisplayMemberPath="Name" SelectedValuePath="Id"/>

        <Label Grid.Row="4" Grid.Column="0" Content="Телефон:"/>
        <TextBox x:Name="txtPhone" Grid.Row="4" Grid.Column="1" Margin="0,0,0,8"/>

        <Label Grid.Row="5" Grid.Column="0" Content="Дата рождения:"/>
        <DatePicker x:Name="dpBirthDate" Grid.Row="5" Grid.Column="1" Margin="0,0,0,8"/>

        <Label Grid.Row="6" Grid.Column="0" Content="Образование:"/>
        <TextBox x:Name="txtEducation" Grid.Row="6" Grid.Column="1" Margin="0,0,0,8"/>

        <Button Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2" Content="Добавить"
                Height="32" Click="btnAdd_Click"/>
    </Grid>
</Window>
