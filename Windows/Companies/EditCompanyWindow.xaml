<Window x:Class="MuseumApp.Windows.Companies.EditCompanyWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Title="Изменить компанию" Height="320" Width="480" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
<Grid Margin="16"><Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
<Label Content="Название:"/><TextBox x:Name="txtName" Grid.Row="1" Margin="0,0,0,8"/>
<Label Grid.Row="2" Content="ИНН:"/><TextBox x:Name="txtInn" Grid.Row="2" Margin="0,0,0,8"/>
<Label Grid.Row="3" Content="Юр. адрес:"/><TextBox x:Name="txtAddress" Grid.Row="3" Margin="0,0,0,8"/>
<Label Grid.Row="4" Content="Телефон:"/><TextBox x:Name="txtPhone" Grid.Row="4" Margin="0,0,0,8"/>
<Label Grid.Row="5" Content="E-mail:"/><TextBox x:Name="txtEmail" Grid.Row="5" Margin="0,0,0,8"/>
<Button Grid.Row="6" Content="Сохранить" Height="32" Click="btnSave_Click"/></Grid></Window>
