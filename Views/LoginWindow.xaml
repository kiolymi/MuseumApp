<Window x:Class="MuseumApp.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ИС Музейный комплекс — вход"
        Background="#F2F6FA"
        FontFamily="Segoe UI"
        FontSize="14"
        Foreground="#1E2D3D"
        Width="1600" Height="900"
        MinWidth="1600" MinHeight="900"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Border Background="#7EC8F0" Opacity="0.12"/>

        <Border Background="#FFFFFF"
                BorderBrush="#C8D8E8"
                BorderThickness="1"
                CornerRadius="12"
                Width="420"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Padding="32">
            <StackPanel>
                <Image Source="/Assets/logo.png" Height="72" Margin="0,0,0,16"
                       HorizontalAlignment="Center" Stretch="Uniform"/>

                <TextBlock Text="ИС «Музейный комплекс»"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="#1A3D5C"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,6"/>

                <TextBlock Text="Введите логин и пароль для входа"
                           FontSize="14"
                           Foreground="#5E7285"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Margin="0,0,0,24"/>

                <TextBlock Text="Логин" FontWeight="SemiBold" Foreground="#1E2D3D" Margin="0,0,0,6"/>
                <Border Background="#FFFFFF"
                        BorderBrush="#C8D8E8"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="2"
                        Margin="0,0,0,12">
                    <TextBox x:Name="txtLogin"
                             Height="34"
                             Padding="10,6"
                             BorderThickness="0"
                             Background="Transparent"
                             Foreground="#1E2D3D"/>
                </Border>

                <TextBlock Text="Пароль" FontWeight="SemiBold" Foreground="#1E2D3D" Margin="0,0,0,6"/>
                <Border Background="#FFFFFF"
                        BorderBrush="#C8D8E8"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="2"
                        Margin="0,0,0,12">
                    <PasswordBox x:Name="txtPassword"
                                 Height="34"
                                 Padding="10,6"
                                 BorderThickness="0"
                                 Background="Transparent"/>
                </Border>

                <Button x:Name="btnLogin"
                        Content="Войти"
                        Height="40"
                        MinWidth="100"
                        Padding="18,0"
                        Background="#1A3D5C"
                        Foreground="White"
                        FontWeight="SemiBold"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="btnLogin_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
