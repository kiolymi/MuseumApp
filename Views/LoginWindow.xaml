<Window x:Class="MuseumApp.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="ИС Музейный комплекс — вход"
        Height="320" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                   Text="Вход в систему"
                   FontSize="18" FontWeight="Bold"
                   Margin="0,0,0,16"/>

        <Label Grid.Row="1" Grid.Column="0" Content="Роль:" VerticalAlignment="Center"/>
        <ComboBox x:Name="cmbRole" Grid.Row="1" Grid.Column="1"
                  Height="28" VerticalContentAlignment="Center">
            <ComboBoxItem Content="Администратор (ivanov)" Tag="admin_museum"/>
            <ComboBoxItem Content="Куратор (petrova)" Tag="curator_museum"/>
            <ComboBoxItem Content="Кассир (pavlov)" Tag="cashier_museum"/>
        </ComboBox>

        <Label Grid.Row="2" Grid.Column="0" Content="Логин:" VerticalAlignment="Center" Margin="0,12,0,0"/>
        <TextBox x:Name="txtLogin" Grid.Row="2" Grid.Column="1"
                 Height="28" VerticalContentAlignment="Center" Margin="0,12,0,0"/>

        <Label Grid.Row="3" Grid.Column="0" Content="Пароль:" VerticalAlignment="Center" Margin="0,12,0,0"/>
        <PasswordBox x:Name="txtPassword" Grid.Row="3" Grid.Column="1"
                     Height="28" VerticalAlignment="Center" Margin="0,12,0,0"/>

        <Button x:Name="btnLogin" Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2"
                Content="Войти" Height="32" Margin="0,20,0,0"
                Click="btnLogin_Click"/>
    </Grid>
</Window>
