<Window x:Class="MuseumApp.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ИС Музейный комплекс — вход"
        Style="{StaticResource ShellWindow}"
        Width="1600" Height="900"
        MinWidth="1600" MinHeight="900"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Border Background="{StaticResource BrushAccentLight}" Opacity="0.12"/>

        <Border Style="{StaticResource CardBorder}"
                Width="420" VerticalAlignment="Center" HorizontalAlignment="Center"
                Padding="32">
            <StackPanel>
                <Image Source="/Assets/logo.png" Height="72" Margin="0,0,0,16"
                       HorizontalAlignment="Center" Stretch="Uniform"/>

                <TextBlock Text="ИС «Музейный комплекс»"
                           Style="{StaticResource TitleText}"
                           HorizontalAlignment="Center" Margin="0,0,0,6"/>

                <TextBlock Text="Введите логин и пароль для входа"
                           Style="{StaticResource SubtitleText}"
                           TextAlignment="Center" Margin="0,0,0,24"/>

                <TextBlock Text="Логин" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <Border Style="{StaticResource FieldBorder}">
                    <TextBox x:Name="txtLogin"/>
                </Border>

                <TextBlock Text="Пароль" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <Border Style="{StaticResource FieldBorder}" Margin="0,0,0,12">
                    <PasswordBox x:Name="txtPassword"/>
                </Border>

                <Button x:Name="btnLogin" Content="Войти"
                        Height="40" Click="btnLogin_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
