<Window x:Class="MuseumApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="ИС Музейный комплекс"
        ResizeMode="CanResize">
    <Grid Margin="12">
        <TabControl x:Name="mainTabs">
            <TabItem x:Name="tabExhibitions" Header="Выставки">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <DataGrid x:Name="dg_exhibitions" Grid.Row="0"
                              AutoGenerateColumns="True" IsReadOnly="True" CanUserAddRows="False"/>
                    <Button x:Name="btn_add_exhibitions" Grid.Row="1" Content="Добавить"
                            Margin="0,8,0,0" Height="32" HorizontalAlignment="Left" MinWidth="120"
                            Click="btn_add_exhibitions_Click"/>
                </Grid>
            </TabItem>
            <TabItem x:Name="tabExhibits" Header="Экспонаты">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <DataGrid x:Name="dg_exhibits" Grid.Row="0"
                              AutoGenerateColumns="True" IsReadOnly="True" CanUserAddRows="False"/>
                    <Button x:Name="btn_add_exhibits" Grid.Row="1" Content="Добавить"
                            Margin="0,8,0,0" Height="32" HorizontalAlignment="Left" MinWidth="120"
                            Click="btn_add_exhibits_Click"/>
                </Grid>
            </TabItem>
            <TabItem x:Name="tabCollections" Header="Коллекции">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <DataGrid x:Name="dg_collections" Grid.Row="0"
                              AutoGenerateColumns="True" IsReadOnly="True" CanUserAddRows="False"/>
                    <Button x:Name="btn_add_collections" Grid.Row="1" Content="Добавить"
                            Margin="0,8,0,0" Height="32" HorizontalAlignment="Left" MinWidth="120"
                            Click="btn_add_collections_Click"/>
                </Grid>
            </TabItem>
            <TabItem x:Name="tabHalls" Header="Залы">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <DataGrid x:Name="dg_halls" Grid.Row="0"
                              AutoGenerateColumns="True" IsReadOnly="True" CanUserAddRows="False"/>
                    <Button x:Name="btn_add_halls" Grid.Row="1" Content="Добавить"
                            Margin="0,8,0,0" Height="32" HorizontalAlignment="Left" MinWidth="120"
                            Click="btn_add_halls_Click"/>
                </Grid>
            </TabItem>
            <TabItem x:Name="tabAuthors" Header="Авторы">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <DataGrid x:Name="dg_authors" Grid.Row="0"
                              AutoGenerateColumns="True" IsReadOnly="True" CanUserAddRows="False"/>
                    <Button x:Name="btn_add_authors" Grid.Row="1" Content="Добавить"
                            Margin="0,8,0,0" Height="32" HorizontalAlignment="Left" MinWidth="120"
                            Click="btn_add_authors_Click"/>
                </Grid>
            </TabItem>
            <TabItem x:Name="tabVisitors" Header="Посетители">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <DataGrid x:Name="dg_visitors" Grid.Row="0"
                              AutoGenerateColumns="True" IsReadOnly="True" CanUserAddRows="False"/>
                    <Button x:Name="btn_add_visitors" Grid.Row="1" Content="Добавить"
                            Margin="0,8,0,0" Height="32" HorizontalAlignment="Left" MinWidth="120"
                            Click="btn_add_visitors_Click"/>
                </Grid>
            </TabItem>
            <TabItem x:Name="tabExhibitionTickets" Header="Билеты на выставки">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <DataGrid x:Name="dg_exhibitionTickets" Grid.Row="0"
                              AutoGenerateColumns="True" IsReadOnly="True" CanUserAddRows="False"/>
                    <Button x:Name="btn_add_exhibitionTickets" Grid.Row="1" Content="Добавить"
                            Margin="0,8,0,0" Height="32" HorizontalAlignment="Left" MinWidth="120"
                            Click="btn_add_exhibitionTickets_Click"/>
                </Grid>
            </TabItem>
            <TabItem x:Name="tabExcursionTickets" Header="Билеты на экскурсии">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <DataGrid x:Name="dg_excursionTickets" Grid.Row="0"
                              AutoGenerateColumns="True" IsReadOnly="True" CanUserAddRows="False"/>
                    <Button x:Name="btn_add_excursionTickets" Grid.Row="1" Content="Добавить"
                            Margin="0,8,0,0" Height="32" HorizontalAlignment="Left" MinWidth="120"
                            Click="btn_add_excursionTickets_Click"/>
                </Grid>
            </TabItem>
            <TabItem x:Name="tabExcursions" Header="Экскурсии">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <DataGrid x:Name="dg_excursions" Grid.Row="0"
                              AutoGenerateColumns="True" IsReadOnly="True" CanUserAddRows="False"/>
                    <Button x:Name="btn_add_excursions" Grid.Row="1" Content="Добавить"
                            Margin="0,8,0,0" Height="32" HorizontalAlignment="Left" MinWidth="120"
                            Click="btn_add_excursions_Click"/>
                </Grid>
            </TabItem>
            <TabItem x:Name="tabPrivileges" Header="Льготы">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <DataGrid x:Name="dg_privileges" Grid.Row="0"
                              AutoGenerateColumns="True" IsReadOnly="True" CanUserAddRows="False"/>
                    <Button x:Name="btn_add_privileges" Grid.Row="1" Content="Добавить"
                            Margin="0,8,0,0" Height="32" HorizontalAlignment="Left" MinWidth="120"
                            Click="btn_add_privileges_Click"/>
                </Grid>
            </TabItem>
            <TabItem x:Name="tabEmployees" Header="Сотрудники">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <DataGrid x:Name="dg_employees" Grid.Row="0"
                              AutoGenerateColumns="True" IsReadOnly="True" CanUserAddRows="False"/>
                    <Button x:Name="btn_add_employees" Grid.Row="1" Content="Добавить"
                            Margin="0,8,0,0" Height="32" HorizontalAlignment="Left" MinWidth="120"
                            Click="btn_add_employees_Click"/>
                </Grid>
            </TabItem>
            <TabItem x:Name="tabEvents" Header="Мероприятия">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <DataGrid x:Name="dg_events" Grid.Row="0"
                              AutoGenerateColumns="True" IsReadOnly="True" CanUserAddRows="False"/>
                    <Button x:Name="btn_add_events" Grid.Row="1" Content="Добавить"
                            Margin="0,8,0,0" Height="32" HorizontalAlignment="Left" MinWidth="120"
                            Click="btn_add_events_Click"/>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
