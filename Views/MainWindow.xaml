<Window x:Class="MuseumApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ИС Музейный комплекс"
        Background="#F2F6FA"
        FontFamily="Segoe UI"
        FontSize="14"
        Foreground="#1E2D3D"
        Width="1600" Height="900"
        MinWidth="1600" MinHeight="900"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#FFFFFF"
                BorderBrush="#C8D8E8"
                BorderThickness="0,0,0,1"
                Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="/Assets/logo.png" Height="36" Margin="0,0,14,0"/>
                    <TextBlock Text="Музейный комплекс"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#1A3D5C"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border Background="#E8F2FA" CornerRadius="8" Padding="12,6" Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Пользователь:" Foreground="#5E7285" Margin="0,0,6,0"/>
                            <TextBlock x:Name="txtUser" FontWeight="SemiBold" Foreground="#1E2D3D"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#E8F2FA" CornerRadius="8" Padding="12,6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Роль:" Foreground="#5E7285" Margin="0,0,6,0"/>
                            <TextBlock x:Name="txtRole" FontWeight="SemiBold" Foreground="#1E2D3D"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Button x:Name="btnLogout" Grid.Column="2"
                        Content="Выйти"
                        Height="36"
                        MinWidth="100"
                        Padding="18,0"
                        Background="#FFFFFF"
                        Foreground="#1A3D5C"
                        BorderBrush="#C8D8E8"
                        BorderThickness="1"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Click="btnLogout_Click"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="200"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="#FFFFFF"
                    BorderBrush="#C8D8E8"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="12">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Таблицы"
                               FontWeight="SemiBold" FontSize="15"
                               Foreground="#1A3D5C"
                               Margin="4,0,0,10"/>
                    <TreeView x:Name="treeTables"
                              Background="Transparent"
                              BorderThickness="0"
                              Foreground="#1E2D3D"
                              SelectedItemChanged="treeTables_SelectedItemChanged"/>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1" Width="12" HorizontalAlignment="Stretch"
                          Background="Transparent"/>

            <Border Grid.Column="2"
                    Background="#FFFFFF"
                    BorderBrush="#C8D8E8"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal"
                                HorizontalAlignment="Right" Margin="0,0,0,12">
                        <Button x:Name="btnAdd" Content="Добавить"
                                Height="36" MinWidth="100" Padding="18,0"
                                Background="#1A3D5C" Foreground="White"
                                FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"
                                Margin="0,0,8,0" Click="btnAdd_Click"/>
                        <Button x:Name="btnEdit" Content="Изменить"
                                Height="36" MinWidth="100" Padding="18,0"
                                Background="#FFFFFF" Foreground="#1A3D5C"
                                BorderBrush="#C8D8E8" BorderThickness="1"
                                FontWeight="SemiBold" Cursor="Hand"
                                Margin="0,0,8,0" Click="btnEdit_Click"/>
                        <Button x:Name="btnDelete" Content="Удалить"
                                Height="36" MinWidth="100" Padding="18,0"
                                Background="#C44B4B" Foreground="White"
                                FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"
                                Click="btnDelete_Click"/>
                    </StackPanel>

                    <DataGrid x:Name="dgMain" Grid.Row="1"
                              AutoGenerateColumns="True"
                              Background="#FFFFFF"
                              BorderBrush="#C8D8E8"
                              BorderThickness="1"
                              RowBackground="#FFFFFF"
                              AlternatingRowBackground="#F8FBFE"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#C8D8E8"
                              HeadersVisibility="Column"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              Foreground="#1E2D3D"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
