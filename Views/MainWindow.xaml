<Window x:Class="MuseumApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ИС Музейный комплекс"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        MinWidth="900" MinHeight="500">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="0,0,0,12" BorderBrush="#DDD" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Пользователь:" FontWeight="SemiBold" Margin="0,0,6,0"/>
                    <TextBlock x:Name="txtUser" Margin="0,0,20,0"/>
                    <TextBlock Text="Роль:" FontWeight="SemiBold" Margin="0,0,6,0"/>
                    <TextBlock x:Name="txtRole"/>
                </StackPanel>
                <Button x:Name="btnLogout" Grid.Column="1"
                        Content="Выйти" Height="32" MinWidth="100"
                        Click="btnLogout_Click"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" MinWidth="180"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TreeView x:Name="treeTables" Grid.Column="0"
                      SelectedItemChanged="treeTables_SelectedItemChanged"/>

            <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch"
                          Background="Transparent" ShowsPreview="True"/>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal"
                            HorizontalAlignment="Right" Margin="0,0,0,8">
                    <Button x:Name="btnAdd" Content="Добавить"
                            Height="32" MinWidth="110" Margin="0,0,8,0"
                            Click="btnAdd_Click"/>
                    <Button x:Name="btnEdit" Content="Изменить"
                            Height="32" MinWidth="110" Margin="0,0,8,0"
                            Click="btnEdit_Click"/>
                    <Button x:Name="btnDelete" Content="Удалить"
                            Height="32" MinWidth="110"
                            Click="btnDelete_Click"/>
                </StackPanel>

                <DataGrid x:Name="dgMain" Grid.Row="1"
                          AutoGenerateColumns="True"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          SelectionMode="Single"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
