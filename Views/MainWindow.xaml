<Window x:Class="MuseumApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ИС Музейный комплекс"
        Style="{StaticResource ShellWindow}"
        Width="1600" Height="900"
        MinWidth="1600" MinHeight="900"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource HeaderBar}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="/Assets/logo.png" Height="36" Margin="0,0,14,0"/>
                    <TextBlock Text="Музейный комплекс" Style="{StaticResource TitleText}"
                               FontSize="18" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border Background="#E8F2FA" CornerRadius="8" Padding="12,6" Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Пользователь:" Foreground="{StaticResource BrushMuted}" Margin="0,0,6,0"/>
                            <TextBlock x:Name="txtUser" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#E8F2FA" CornerRadius="8" Padding="12,6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Роль:" Foreground="{StaticResource BrushMuted}" Margin="0,0,6,0"/>
                            <TextBlock x:Name="txtRole" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Button x:Name="btnLogout" Grid.Column="2"
                        Content="Выйти" Style="{StaticResource SecondaryButton}"
                        Click="btnLogout_Click"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="200"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardBorder}" Padding="12">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Таблицы"
                               FontWeight="SemiBold" FontSize="15"
                               Foreground="{StaticResource BrushPrimary}"
                               Margin="4,0,0,10"/>
                    <TreeView x:Name="treeTables"
                              SelectedItemChanged="treeTables_SelectedItemChanged"/>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1" Width="12" HorizontalAlignment="Stretch"
                          Background="Transparent"/>

            <Border Grid.Column="2" Style="{StaticResource CardBorder}" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal"
                                HorizontalAlignment="Right" Margin="0,0,0,12">
                        <Button x:Name="btnAdd" Content="Добавить"
                                Margin="0,0,8,0" Click="btnAdd_Click"/>
                        <Button x:Name="btnEdit" Content="Изменить"
                                Style="{StaticResource SecondaryButton}"
                                Margin="0,0,8,0" Click="btnEdit_Click"/>
                        <Button x:Name="btnDelete" Content="Удалить"
                                Style="{StaticResource DangerButton}"
                                Click="btnDelete_Click"/>
                    </StackPanel>

                    <DataGrid x:Name="dgMain" Grid.Row="1"
                              AutoGenerateColumns="True"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
