<Window x:Class="MuseumApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ИС Музейный комплекс"
        MinWidth="960" MinHeight="600"
        ResizeMode="CanResize">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="12,10" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1">
            <Grid>
                <TextBlock x:Name="txtUserHeader" VerticalAlignment="Center" FontSize="14"/>
                <Button x:Name="btnLogout" Content="Выйти"
                        HorizontalAlignment="Right" Height="32" MinWidth="100"
                        Click="btnLogout_Click"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" MinWidth="220"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <DockPanel Grid.Column="0" Margin="12,12,0,12">
                <TextBox x:Name="txtSearch" DockPanel.Dock="Top" Margin="0,0,0,8"
                         ToolTip="Поиск таблицы"
                         TextChanged="txtSearch_TextChanged"/>
                <TreeView x:Name="treeTables" SelectedItemChanged="treeTables_SelectedItemChanged"/>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="Transparent"/>

            <Grid Grid.Column="2" Margin="8,12,12,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <TextBlock x:Name="txtTableTitle" FontSize="20" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="btnAdd" Content="Добавить"
                                Height="32" MinWidth="110" Margin="0,0,8,0" Click="btnAdd_Click"/>
                        <Button x:Name="btnEdit" Content="Изменить"
                                Height="32" MinWidth="110" Margin="0,0,8,0" Click="btnEdit_Click"/>
                        <Button x:Name="btnDelete" Content="Удалить"
                                Height="32" MinWidth="110" Click="btnDelete_Click"/>
                    </StackPanel>
                </Grid>

                <StackPanel x:Name="panelTicketFilter" Grid.Row="1" Orientation="Horizontal"
                            Margin="0,0,0,8" Visibility="Collapsed">
                    <Label Content="Период с:" VerticalAlignment="Center"/>
                    <DatePicker x:Name="dpTicketFrom" Width="130" Margin="4,0,12,0"/>
                    <Label Content="по:" VerticalAlignment="Center"/>
                    <DatePicker x:Name="dpTicketTo" Width="130" Margin="4,0,12,0"/>
                    <Button Content="Найти" Height="32" MinWidth="90" Click="btnFilterTickets_Click"/>
                    <Button Content="Сбросить" Height="32" MinWidth="90" Margin="8,0,0,0"
                            Click="btnResetTickets_Click"/>
                </StackPanel>

                <DataGrid x:Name="dgData" Grid.Row="2"
                          AutoGenerateColumns="True" IsReadOnly="True"
                          CanUserAddRows="False" SelectionMode="Single"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
